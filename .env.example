# ---------------------------------------------------------------------------
# Céal — Environment Variables
# ---------------------------------------------------------------------------
# Copy to .env and fill in values. Never commit .env to git.

# Database URL
# SQLite (local development):
DATABASE_URL=sqlite+aiosqlite:///data/ceal.db
# PostgreSQL (Docker / Cloud Run):
# DATABASE_URL=postgresql+asyncpg://ceal:password@localhost:5432/ceal

# Claude API key (for LLM ranker + tailoring engine)
LLM_API_KEY=

# Web server port
PORT=8000

# GCP deployment (Cloud Run)
GCP_PROJECT_ID=
GCP_REGION=us-east1
CLOUD_SQL_INSTANCE=

# Vertex AI (optional — regime classification)
# Set VERTEX_PROJECT_ID to enable. Leave blank to skip classification.
VERTEX_PROJECT_ID=
VERTEX_LOCATION=us-east1
VERTEX_MODEL=gemini-2.0-flash
